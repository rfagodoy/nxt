generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// NOTA SQL Server: o conector não suporta os tipos `Json` nem `enum`, e proíbe
// caminhos de cascade múltiplos/cíclicos. Por isso, campos antes `Json` viraram
// `String @db.NVarChar(Max)` (JSON serializado, (de)serializado na PrismaService
// via middleware), enums viraram `String`, e relações que formavam cascade
// múltiplo usam `onDelete/onUpdate: NoAction` (cascade tratado na aplicação).

// ─── Tenants ────────────────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(cuid())
  externalId String   @unique // id da organização no IdP (Keycloak)
  name       String
  slug       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processes ProcessDefinition[]
  modules   Module[]

  @@map("organizations")
}

// ─── Processo BPMN ──────────────────────────────────────────────────────────

model ProcessDefinition {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  bpmnXml        String   @db.NVarChar(Max)
  formSchema     String   @db.NVarChar(Max) // [JSON] schema dos forms por step
  status         String   @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instances    ProcessInstance[]
  module       Module?

  @@map("process_definitions")
}

model ProcessInstance {
  id                  String    @id @default(cuid())
  processDefinitionId String
  status              String    @default("RUNNING") // RUNNING | COMPLETED | CANCELLED | ERROR
  currentStep         String
  data                String    @default("{}") @db.NVarChar(Max) // [JSON]
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt

  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  records           ModuleRecord[]

  @@map("process_instances")
}

// ─── Módulos gerados ─────────────────────────────────────────────────────────

model Module {
  id                  String   @id @default(cuid())
  organizationId      String
  processDefinitionId String   @unique
  name                String
  slug                String
  schema              String   @db.NVarChar(Max) // [JSON] estrutura das colunas/campos gerados
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  records           ModuleRecord[]

  @@unique([organizationId, slug])
  @@map("modules")
}

model ModuleRecord {
  id                String   @id @default(cuid())
  moduleId          String
  processInstanceId String   @unique
  data              String   @db.NVarChar(Max) // [JSON] dados dinâmicos coletados pelo processo
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  module          Module          @relation(fields: [moduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processInstance ProcessInstance @relation(fields: [processInstanceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents       Document[]

  @@map("module_records")
}

// ─── Parceiros ───────────────────────────────────────────────────────────────

model Partner {
  id             String   @id @default(cuid())
  organizationId String
  categoria      String
  status         String   @default("EM_CADASTRAMENTO")
  documento      String?
  razaoSocial    String
  nomeFantasia   String?
  ie             String?
  im             String?
  rg             String?
  orgaoExpedidor String?
  dataNascimento String?
  paisOrigem     String?
  contatos       String   @default("[]") @db.NVarChar(Max) // [JSON]
  enderecos      String   @default("[]") @db.NVarChar(Max) // [JSON]
  bancos         String   @default("[]") @db.NVarChar(Max) // [JSON]
  socios         String   @default("[]") @db.NVarChar(Max) // [JSON]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs PartnerAuditLog[]

  @@index([organizationId])
  @@map("partners")
}

model PartnerAuditLog {
  id        String   @id @default(cuid())
  partnerId String
  user      String
  event     String   // EM_CADASTRAMENTO | ATIVADO | INATIVADO | REATIVADO | ALTERADO
  motivo    String?
  changes   String   @default("[]") @db.NVarChar(Max) // [JSON] [{ field, label, before, after }]
  createdAt DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_audit_logs")
}

// ─── Contratos ────────────────────────────────────────────────────────────────

model Contract {
  id                  String   @id @default(cuid())
  organizationId      String
  numero              String
  titulo              String
  tipo                String
  descricao           String?
  objeto              String   @default("[]") @db.NVarChar(Max) // [JSON]
  situacao            String   @default("PENDENTE")
  inicioVigencia      String?
  terminoVigencia     String?
  prazoIndeterminado  Boolean  @default(false)
  dataAssinatura      String?
  moeda               String   @default("BRL")
  valorTotal          Float    @default(0)
  valorParcela        Float?
  condicaoPagamento   String?
  complementoValor    String?
  renovacaoAutomatica Boolean  @default(false)
  observacoes         String?
  partes              String   @default("[]") @db.NVarChar(Max) // [JSON]
  reajustes           String   @default("[]") @db.NVarChar(Max) // [JSON]
  documentos          String   @default("[]") @db.NVarChar(Max) // [JSON]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@map("contracts")
}

// ─── Documentos ──────────────────────────────────────────────────────────────

model Document {
  id             String   @id @default(cuid())
  moduleRecordId String
  name           String
  fileKey        String   // chave no Cloudflare R2
  fileSize       Int
  mimeType       String
  uploadedAt     DateTime @default(now())

  moduleRecord ModuleRecord @relation(fields: [moduleRecordId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("documents")
}

// ─── Configurações da aplicação (KV genérico) ────────────────────────────────
// Substitui o localStorage: tabelas auxiliares, definições de campos/seções,
// visões, ordem de coluna, rascunhos. userId="" = nível organização (compartilhado);
// quando houver login, configurações pessoais gravam com o id do usuário.

model AppSetting {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @default("")
  key            String
  value          String   @db.NVarChar(Max) // [JSON]
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, userId, key])
  @@index([organizationId, key])
  @@map("app_settings")
}

// ─── Estrutura organizacional ─────────────────────────────────────────────────
// Empresas do grupo + organograma (unidades organizacionais em árvore).
// Cada unidade tem uma "natureza": administrativa, centro de custo ou centro de lucro.

model GroupCompany {
  id             String   @id @default(cuid())
  organizationId String
  codigo         String?  // alfanumérico, até 15 posições, manual
  razaoSocial    String
  nomeFantasia   String?
  cnpj           String?
  status         String   @default("ATIVA") // ATIVA | INATIVA
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orgUnits OrgUnit[]

  @@index([organizationId])
  @@map("group_companies")
}

model OrgUnit {
  id             String   @id @default(cuid())
  organizationId String
  groupCompanyId String
  parentId       String?
  natureza       String   @default("ADMINISTRATIVA") // ADMINISTRATIVA | CENTRO_CUSTO | CENTRO_LUCRO
  codigo         String?
  nome           String
  responsavel    String?
  status         String   @default("ATIVA") // ATIVA | INATIVA
  usuarios       String   @default("[]") @db.NVarChar(Max) // [JSON] usuários envolvidos (lista livre)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  groupCompany GroupCompany @relation(fields: [groupCompanyId], references: [id], onDelete: Cascade)
  parent       OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     OrgUnit[]    @relation("OrgUnitTree")

  @@index([organizationId])
  @@index([groupCompanyId])
  @@map("org_units")
}
