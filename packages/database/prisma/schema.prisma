generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// NOTA SQL Server: o conector não suporta os tipos `Json` nem `enum`, e proíbe
// caminhos de cascade múltiplos/cíclicos. Por isso, campos antes `Json` viraram
// `String @db.NVarChar(Max)` (JSON serializado, (de)serializado na PrismaService
// via middleware), enums viraram `String`, e relações que formavam cascade
// múltiplo usam `onDelete/onUpdate: NoAction` (cascade tratado na aplicação).

// ─── Tenants ────────────────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(cuid())
  externalId String   @unique // id externo opcional (provisionamento/SSO); em dev = id
  name       String
  slug       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processes ProcessDefinition[]
  modules   Module[]
  users     User[]

  @@map("organizations")
}

// ─── Usuários (autenticação própria) ─────────────────────────────────────────
// Identidade gerida pela própria aplicação (sem IdP externo). A senha é guardada
// como hash scrypt; o login emite um access token JWT curto (HS256) + um refresh
// token opaco. O par (organizationId, email) é único — e-mail se repete entre
// tenants, não dentro.

model User {
  id                  String    @id @default(cuid())
  organizationId      String
  email               String
  passwordHash        String
  name                String
  role                String    @default("user") // 'admin' | 'user'
  status              String    @default("ATIVO") // 'ATIVO' | 'INATIVO'
  lastLoginAt         DateTime?
  // Anti-brute-force: bloqueio temporário da conta após falhas seguidas.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

// Refresh tokens (opacos) para renovar o access token sem novo login. Guardamos
// só o HASH (sha256); rotação a cada uso, com revogação e detecção de reuso.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Auditoria de login (sucesso e falha). Sem FK de propósito: o registro deve
// sobreviver à deleção do usuário, para investigação de incidentes.
model LoginEvent {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  email          String
  success        Boolean
  reason         String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("login_events")
}

// ─── Processo BPMN ──────────────────────────────────────────────────────────

model ProcessDefinition {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  bpmnXml        String   @db.NVarChar(Max)
  formSchema     String   @db.NVarChar(Max) // [JSON] schema dos forms por step
  compiledGraph  String?  @db.NVarChar(Max) // [JSON] grafo normalizado (WfGraph) compilado do BPMN na ativação
  version        Int      @default(1) // versão da definição (incrementa a cada recompilação/ativação)
  status         String   @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instances    ProcessInstance[]
  module       Module?

  @@map("process_definitions")
}

model ProcessInstance {
  id                  String    @id @default(cuid())
  processDefinitionId String
  definitionVersion   Int       @default(1) // versão do grafo com que esta instância roda (imutável após o start)
  revision            Int       @default(0) // lock otimístico do `state` (concorrência entre conclusões)
  status              String    @default("RUNNING") // RUNNING | COMPLETED | CANCELLED | ERROR
  currentStep         String? // legado (motor linear antigo); o motor por token usa `state`
  data                String    @default("{}") @db.NVarChar(Max) // [JSON] legado — dados achatados do motor antigo
  state               String    @default("{}") @db.NVarChar(Max) // [JSON] WfState do motor por token (tokens/variables/joinCounts)
  graphSnapshot       String?   @db.NVarChar(Max) // [JSON] WfGraph congelado no start (imune a reativação/edição do diagrama)
  startedBy           String? // quem iniciou (nome do @CurrentUser)
  startedById         String? // id estável de quem iniciou
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt

  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  records           ModuleRecord[]
  tasks             WorkflowTask[]

  @@map("process_instances")
}

// Caixa de tarefas: cada userTask ativo do motor vira uma linha aqui (a "inbox").
// Precisa ser relacional (não JSON) porque é consultada por executor/papel/status.
model WorkflowTask {
  id          String    @id @default(cuid())
  instanceId  String
  tokenId     String // token do motor que criou esta tarefa (para retomar a execução)
  nodeId      String // id do nó (userTask) no grafo
  name        String?
  role        String? // executor por papel/lane (F2)
  assignee    String? // executor por usuário direto (F2)
  assignees   String  @default("[]") @db.NVarChar(Max) // [JSON] userId[] resolvidos do executor papel+entidade (Papéis/Responsáveis)
  formRef     String? // tela/formulário associado à atividade (F3)
  status      String    @default("PENDING") // PENDING | DONE | CANCELED
  dueAt       DateTime? // prazo/SLA (F4)
  escalatedAt DateTime? // quando a varredura marcou a tarefa como vencida/escalonada (F4)
  data        String    @default("{}") @db.NVarChar(Max) // [JSON] dados preenchidos ao concluir
  completedBy String? // quem concluiu (nome do @CurrentUser)
  completedById String? // id estável do usuário que concluiu
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  instance ProcessInstance @relation(fields: [instanceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([instanceId])
  @@index([status])
  @@map("workflow_tasks")
}

// Papel de negócio (executor) que o cliente define e associa a pessoas. As
// atividades (userTask/lane) apontam para um papel; a caixa de tarefas mostra a
// atividade a quem participa dele. Sem FK de propósito (como a auditoria) para
// não criar caminho de cascade; o escopo por org é pelo scalar organizationId.
model WorkflowRole {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  members        String   @default("[]") @db.NVarChar(Max) // [JSON] userId[] dos participantes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("workflow_roles")
}

// Atribuição de uma PESSOA (User) a um PAPEL de referência PESSOA dentro de uma
// entidade (empresa/parceiro/unidade/contrato) ou global (ORG). É o "Responsável".
// Relacional (não JSON) para consultar dos dois lados: quem é o papel X da entidade
// Y, e onde o usuário U tem papel. Sem FK de propósito (como WorkflowRole/auditoria):
// userId/entityId são scalars; a limpeza ao excluir usuário/entidade é da aplicação.
model RoleAssignment {
  id             String   @id @default(cuid())
  organizationId String
  papelId        String   // id do papel no catálogo (AppSetting nxt:settings:contratos:papeis:v2)
  entityType     String   // EMPRESA | PARCEIRO | UNIDADE | CONTRATO | ORG
  entityId       String?  // id da entidade-anfitriã; null para ORG (papel global)
  userId         String   // id do User responsável
  createdAt      DateTime @default(now())

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, papelId])
  @@index([organizationId, userId])
  @@map("role_assignments")
}

// ─── Módulos gerados ─────────────────────────────────────────────────────────

model Module {
  id                  String   @id @default(cuid())
  organizationId      String
  processDefinitionId String   @unique
  name                String
  slug                String
  schema              String   @db.NVarChar(Max) // [JSON] estrutura das colunas/campos gerados
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  records           ModuleRecord[]

  @@unique([organizationId, slug])
  @@map("modules")
}

model ModuleRecord {
  id                String   @id @default(cuid())
  moduleId          String
  processInstanceId String   @unique
  data              String   @db.NVarChar(Max) // [JSON] dados dinâmicos coletados pelo processo
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  module          Module          @relation(fields: [moduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processInstance ProcessInstance @relation(fields: [processInstanceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents       Document[]

  @@map("module_records")
}

// ─── Parceiros ───────────────────────────────────────────────────────────────

model Partner {
  id             String   @id @default(cuid())
  organizationId String
  categoria      String
  status         String   @default("EM_CADASTRAMENTO")
  documento      String?
  razaoSocial    String
  nomeFantasia   String?
  ie             String?
  im             String?
  rg             String?
  orgaoExpedidor String?
  dataNascimento String?
  dataAbertura   String?  // PJ: data de abertura da empresa (yyyy-mm-dd)
  naturezaJuridica String? // PJ: code do catálogo NaturezaJuridica (QSA)
  cnaePrincipal  String?  // PJ: code do CNAE principal (catálogo Cnae)
  cnaesSecundarios String @default("[]") @db.NVarChar(Max) // [JSON] codes de CNAE
  paisOrigem     String?
  contatos       String   @default("[]") @db.NVarChar(Max) // [JSON]
  enderecos      String   @default("[]") @db.NVarChar(Max) // [JSON]
  bancos         String   @default("[]") @db.NVarChar(Max) // [JSON]
  socios         String   @default("[]") @db.NVarChar(Max) // [JSON]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs PartnerAuditLog[]

  @@index([organizationId])
  @@map("partners")
}

model PartnerAuditLog {
  id        String   @id @default(cuid())
  partnerId String
  user      String   // nome do autor no momento da ação (snapshot; fallback quando userId nulo)
  userId    String?  // id estável do autor → nome resolvido ao vivo na leitura (sem FK, de propósito)
  event     String   // EM_CADASTRAMENTO | ATIVADO | INATIVADO | REATIVADO | ALTERADO
  motivo    String?
  changes   String   @default("[]") @db.NVarChar(Max) // [JSON] [{ field, label, before, after }]
  createdAt DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_audit_logs")
}

// ─── Catálogos de referência (padrões nacionais; GLOBAIS, não por tenant) ────
// Semeados da fonte oficial (CNAE = IBGE; Natureza Jurídica = Receita/QSA). São
// os mesmos para todas as organizações e não são editados pelo usuário — a UI de
// Tabelas é só consulta. Referenciados pelo `code` nos campos do Partner.

model Cnae {
  code      String @id            // subclasse formatada, ex. "4929-9/02"
  descricao String @db.NVarChar(Max)

  @@map("cnaes")
}

model NaturezaJuridica {
  code      String @id            // ex. "206-2"
  descricao String @db.NVarChar(Max)

  @@map("naturezas_juridicas")
}

// ─── Contratos ────────────────────────────────────────────────────────────────

model Contract {
  id                  String   @id @default(cuid())
  organizationId      String
  numero              String
  titulo              String
  tipo                String
  natureza            String?  // DESPESA | RECEITA | AMBOS
  descricao           String?  @db.NVarChar(Max) // texto livre longo
  objeto              String   @default("[]") @db.NVarChar(Max) // [JSON]
  situacao            String   @default("PENDENTE")
  inicioVigencia      String?
  terminoVigencia     String?
  prazoIndeterminado  Boolean  @default(false)
  acaoTermino         String?  // MANUAL | RENOVAR | ENCERRAR — o que fazer no término
  renovacaoAnos       Int?     // prazo da renovação automática
  renovacaoMeses      Int?
  renovacaoDias       Int?
  dataAssinatura      String?
  moeda               String   @default("BRL")
  valorTotal          Float    @default(0)
  valorParcela        Float?
  qtdParcelas         Int?     // nº de parcelas (parcelados de prazo determinado); base p/ reajuste de parcela
  condicaoPagamento   String?
  formaPagamento      String?  // forma de pagamento padrao (id da lookup); dirige geracao de cronograma/renovacao
  complementoValor    String?  @db.NVarChar(Max) // texto livre longo
  renovacaoAutomatica Boolean  @default(false)
  observacoes         String?  @db.NVarChar(Max) // texto livre longo
  partes              String   @default("[]") @db.NVarChar(Max) // [JSON]
  reajustes           String   @default("[]") @db.NVarChar(Max) // [JSON]
  pagamentos          String   @default("[]") @db.NVarChar(Max) // [JSON] — pagamentos realizados (Despesa/Ambos)
  recebimentos        String   @default("[]") @db.NVarChar(Max) // [JSON] — recebimentos realizados (Receita/Ambos)
  aditivos            String   @default("[]") @db.NVarChar(Max) // [JSON] — termos aditivos (alteram término/valor/objeto/partes em vigor)
  documentos          String   @default("[]") @db.NVarChar(Max) // [JSON]
  renovacoes          String   @default("[]") @db.NVarChar(Max) // [JSON] renovações automáticas: [{ id, data, terminoAnterior, novoTermino, automatica }]
  reajustesRealizados String   @default("[]") @db.NVarChar(Max) // [JSON] reajustes efetivamente aplicados: [{ id, reajusteId, competencia, indiceSnapshot, percentual, valorAnterior, valorNovo, dataAplicacao, observacao, user, createdAt }]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  auditLogs     ContractAuditLog[]
  notifications Notification[]

  @@index([organizationId])
  @@map("contracts")
}

model ContractAuditLog {
  id         String   @id @default(cuid())
  contractId String
  user       String   // nome do autor no momento da ação (snapshot; fallback quando userId nulo)
  userId     String?  // id estável do autor → nome resolvido ao vivo na leitura (sem FK, de propósito)
  event      String   // CRIADO | ATUALIZADO | ATIVADO | EM_REVISAO | ENCERRADO | RESCINDIDO | ADITIVO | REAJUSTE | LANCAMENTO | DOCUMENTO
  motivo     String?
  changes    String   @default("[]") @db.NVarChar(Max) // [JSON] [{ field, label, before, after }]
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_audit_logs")
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  contractId     String
  tipo           String   // VIGENCIA | REAJUSTE | CONSUMO
  severidade     String   @default("INFO") // INFO | ALERTA | CRITICO
  titulo         String
  mensagem       String   @db.NVarChar(Max)
  dedupKey       String   // ex.: "vigencia:<contractId>:30" — único por org, evita duplicar
  createdAt      DateTime @default(now())

  contract Contract           @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reads    NotificationRead[]

  @@unique([organizationId, dedupKey])
  @@index([organizationId])
  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@map("notification_reads")
}

// ─── Documentos ──────────────────────────────────────────────────────────────

model Document {
  id             String   @id @default(cuid())
  moduleRecordId String
  name           String
  fileKey        String   // chave no Cloudflare R2
  fileSize       Int
  mimeType       String
  uploadedAt     DateTime @default(now())

  moduleRecord ModuleRecord @relation(fields: [moduleRecordId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("documents")
}

// ─── Configurações da aplicação (KV genérico) ────────────────────────────────
// Substitui o localStorage: tabelas auxiliares, definições de campos/seções,
// visões, ordem de coluna, rascunhos. userId="" = nível organização (compartilhado);
// quando houver login, configurações pessoais gravam com o id do usuário.

model AppSetting {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @default("")
  key            String
  value          String   @db.NVarChar(Max) // [JSON]
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, userId, key])
  @@index([organizationId, key])
  @@map("app_settings")
}

// ─── Personalização de telas (Screens) ───────────────────────────────────────
// Catálogo de "Telas" reutilizáveis (por perfil de acesso e por etapa de processo).
// DEFINIÇÃO: Screen → ScreenSection/ScreenField. Cada campo é NATIVE (visão de um
// dado nativo, via nativeKey) ou CUSTOM (captura de dado novo). VALOR preenchido:
// ScreenFieldValue, normalizado e POLIMÓRFICO por (subjectType, subjectId) — serve
// parceiro, contrato e instância de processo com uma tabela só. Snapshots de
// nome/rótulo preservam histórico/exportação quando a definição muda.

model Screen {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  subjectType    String   @default("FORNECEDOR") // FORNECEDOR | CONTRATO | GENERICA
  status         String   @default("DRAFT")      // DRAFT | ACTIVE | ARCHIVED
  isDefault      Boolean  @default(false)         // tela padrão do cadastro daquele subject (uma por subject)
  isSystem       Boolean  @default(false)         // tela padrão DO SISTEMA (cadastro base; não deletável)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sections ScreenSection[]
  fields   ScreenField[]

  @@index([organizationId, subjectType])
  @@map("screens")
}

model ScreenSection {
  id          String   @id @default(cuid())
  screenId    String
  label       String
  name        String   // slug técnico
  source      String   @default("CUSTOM") // NATIVE (seção nativa da entidade) | CUSTOM
  nativeKey   String?  // quando source=NATIVE: chave da seção nativa (ex.: 'identificacao')
  visible     Boolean  @default(true)
  order       Int      @default(0)
  defaultOpen Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  screen Screen @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@index([screenId])
  @@map("screen_sections")
}

model ScreenField {
  id          String   @id @default(cuid())
  screenId    String
  sectionId   String?  // seção do mesmo screen; sem FK de propósito (integridade na app)
  name        String   // slug técnico
  label       String
  type        String   // text|textarea|number|currency|date|time|datetime|select|multiselect|checkbox|file|email|phone
  source      String   @default("CUSTOM") // NATIVE (campo nativo da entidade) | CUSTOM (captura)
  nativeKey   String?  // quando source=NATIVE: chave do campo nativo (ex.: 'razao_social')
  mode        String   @default("EDIT")   // VIEW | EDIT
  visible     Boolean  @default(true)      // nativo: liga/desliga no cadastro (único atributo editável)
  required    Boolean  @default(false)
  placeholder String?
  options          String? @db.NVarChar(Max) // [JSON] [{ value, label }] (select/multiselect)
  validation       String? @db.NVarChar(Max) // [JSON] { maxLength?, min?, max?, pattern? }
  hiddenCategories String? @db.NVarChar(Max) // [JSON] string[] — tipos de parceiro onde o campo é oculto (visibilidade por tipo; vazio = visível em todos)
  requiredCategories String? @db.NVarChar(Max) // [JSON] string[] — tipos de parceiro onde o campo é obrigatório (por tipo; ausente = cai no required global)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  screen Screen @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@index([screenId])
  @@map("screen_fields")
}

model ScreenFieldValue {
  id                 String   @id @default(cuid())
  organizationId     String
  fieldId            String   // ScreenField.id — sem FK de propósito (valor sobrevive a alterações/remoção da definição)
  subjectType        String   // PARTNER | CONTRACT | PROCESS_INSTANCE
  subjectId          String
  value              String   @db.NVarChar(Max)
  fieldNameSnapshot  String
  fieldLabelSnapshot String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([subjectType, subjectId, fieldId])
  @@index([organizationId, subjectType, subjectId])
  @@index([fieldId])
  @@map("screen_field_values")
}

// ─── Estrutura organizacional ─────────────────────────────────────────────────
// Empresas do grupo + organograma (unidades organizacionais em árvore).
// Cada unidade tem uma "natureza": administrativa, centro de custo ou centro de lucro.

model GroupCompany {
  id             String   @id @default(cuid())
  organizationId String
  codigo         String?  // alfanumérico, até 15 posições, manual
  razaoSocial    String
  nomeFantasia   String?
  cnpj           String?
  ie             String?  // inscrição estadual
  im             String?  // inscrição municipal
  status         String   @default("ATIVA") // ATIVA | INATIVA
  // Campos PJ reaproveitados do cadastro de Parceiros (JSON serializado via middleware).
  contatos       String   @default("[]") @db.NVarChar(Max) // [JSON]
  enderecos      String   @default("[]") @db.NVarChar(Max) // [JSON]
  bancos         String   @default("[]") @db.NVarChar(Max) // [JSON]
  socios         String   @default("[]") @db.NVarChar(Max) // [JSON]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orgUnits OrgUnit[]

  @@index([organizationId])
  @@map("group_companies")
}

model OrgUnit {
  id             String   @id @default(cuid())
  organizationId String
  groupCompanyId String
  parentId       String?
  natureza       String   @default("ADMINISTRATIVA") // ADMINISTRATIVA | CENTRO_CUSTO | CENTRO_LUCRO
  codigo         String?
  nome           String
  responsavel    String?
  status         String   @default("ATIVA") // ATIVA | INATIVA
  usuarios       String   @default("[]") @db.NVarChar(Max) // [JSON] usuários envolvidos (lista livre)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  groupCompany GroupCompany @relation(fields: [groupCompanyId], references: [id], onDelete: Cascade)
  parent       OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     OrgUnit[]    @relation("OrgUnitTree")

  @@index([organizationId])
  @@index([groupCompanyId])
  @@map("org_units")
}
