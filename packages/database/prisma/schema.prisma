generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// NOTA SQL Server: o conector não suporta os tipos `Json` nem `enum`, e proíbe
// caminhos de cascade múltiplos/cíclicos. Por isso, campos antes `Json` viraram
// `String @db.NVarChar(Max)` (JSON serializado, (de)serializado na PrismaService
// via middleware), enums viraram `String`, e relações que formavam cascade
// múltiplo usam `onDelete/onUpdate: NoAction` (cascade tratado na aplicação).

// ─── Tenants ────────────────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(cuid())
  externalId String   @unique // id externo opcional (provisionamento/SSO); em dev = id
  name       String
  slug       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processes ProcessDefinition[]
  modules   Module[]
  users     User[]

  @@map("organizations")
}

// ─── Usuários (autenticação própria) ─────────────────────────────────────────
// Identidade gerida pela própria aplicação (sem IdP externo). A senha é guardada
// como hash scrypt; o login emite um access token JWT curto (HS256) + um refresh
// token opaco. O par (organizationId, email) é único — e-mail se repete entre
// tenants, não dentro.

model User {
  id                  String    @id @default(cuid())
  organizationId      String
  email               String
  passwordHash        String
  name                String
  role                String    @default("user") // 'admin' | 'user'
  status              String    @default("ATIVO") // 'ATIVO' | 'INATIVO'
  lastLoginAt         DateTime?
  // Anti-brute-force: bloqueio temporário da conta após falhas seguidas.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

// Refresh tokens (opacos) para renovar o access token sem novo login. Guardamos
// só o HASH (sha256); rotação a cada uso, com revogação e detecção de reuso.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Auditoria de login (sucesso e falha). Sem FK de propósito: o registro deve
// sobreviver à deleção do usuário, para investigação de incidentes.
model LoginEvent {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  email          String
  success        Boolean
  reason         String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("login_events")
}

// ─── Processo BPMN ──────────────────────────────────────────────────────────

model ProcessDefinition {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  bpmnXml        String   @db.NVarChar(Max)
  formSchema     String   @db.NVarChar(Max) // [JSON] schema dos forms por step
  status         String   @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instances    ProcessInstance[]
  module       Module?

  @@map("process_definitions")
}

model ProcessInstance {
  id                  String    @id @default(cuid())
  processDefinitionId String
  status              String    @default("RUNNING") // RUNNING | COMPLETED | CANCELLED | ERROR
  currentStep         String
  data                String    @default("{}") @db.NVarChar(Max) // [JSON]
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt

  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  records           ModuleRecord[]

  @@map("process_instances")
}

// ─── Módulos gerados ─────────────────────────────────────────────────────────

model Module {
  id                  String   @id @default(cuid())
  organizationId      String
  processDefinitionId String   @unique
  name                String
  slug                String
  schema              String   @db.NVarChar(Max) // [JSON] estrutura das colunas/campos gerados
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  records           ModuleRecord[]

  @@unique([organizationId, slug])
  @@map("modules")
}

model ModuleRecord {
  id                String   @id @default(cuid())
  moduleId          String
  processInstanceId String   @unique
  data              String   @db.NVarChar(Max) // [JSON] dados dinâmicos coletados pelo processo
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  module          Module          @relation(fields: [moduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  processInstance ProcessInstance @relation(fields: [processInstanceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents       Document[]

  @@map("module_records")
}

// ─── Parceiros ───────────────────────────────────────────────────────────────

model Partner {
  id             String   @id @default(cuid())
  organizationId String
  categoria      String
  status         String   @default("EM_CADASTRAMENTO")
  documento      String?
  razaoSocial    String
  nomeFantasia   String?
  ie             String?
  im             String?
  rg             String?
  orgaoExpedidor String?
  dataNascimento String?
  paisOrigem     String?
  contatos       String   @default("[]") @db.NVarChar(Max) // [JSON]
  enderecos      String   @default("[]") @db.NVarChar(Max) // [JSON]
  bancos         String   @default("[]") @db.NVarChar(Max) // [JSON]
  socios         String   @default("[]") @db.NVarChar(Max) // [JSON]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  auditLogs PartnerAuditLog[]

  @@index([organizationId])
  @@map("partners")
}

model PartnerAuditLog {
  id        String   @id @default(cuid())
  partnerId String
  user      String
  event     String   // EM_CADASTRAMENTO | ATIVADO | INATIVADO | REATIVADO | ALTERADO
  motivo    String?
  changes   String   @default("[]") @db.NVarChar(Max) // [JSON] [{ field, label, before, after }]
  createdAt DateTime @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_audit_logs")
}

// ─── Contratos ────────────────────────────────────────────────────────────────

model Contract {
  id                  String   @id @default(cuid())
  organizationId      String
  numero              String
  titulo              String
  tipo                String
  natureza            String?  // DESPESA | RECEITA | AMBOS
  descricao           String?  @db.NVarChar(Max) // texto livre longo
  objeto              String   @default("[]") @db.NVarChar(Max) // [JSON]
  situacao            String   @default("PENDENTE")
  inicioVigencia      String?
  terminoVigencia     String?
  prazoIndeterminado  Boolean  @default(false)
  acaoTermino         String?  // MANUAL | RENOVAR | ENCERRAR — o que fazer no término
  renovacaoAnos       Int?     // prazo da renovação automática
  renovacaoMeses      Int?
  renovacaoDias       Int?
  dataAssinatura      String?
  moeda               String   @default("BRL")
  valorTotal          Float    @default(0)
  valorParcela        Float?
  qtdParcelas         Int?     // nº de parcelas (parcelados de prazo determinado); base p/ reajuste de parcela
  condicaoPagamento   String?
  complementoValor    String?  @db.NVarChar(Max) // texto livre longo
  renovacaoAutomatica Boolean  @default(false)
  observacoes         String?  @db.NVarChar(Max) // texto livre longo
  partes              String   @default("[]") @db.NVarChar(Max) // [JSON]
  reajustes           String   @default("[]") @db.NVarChar(Max) // [JSON]
  pagamentos          String   @default("[]") @db.NVarChar(Max) // [JSON] — pagamentos realizados (Despesa/Ambos)
  recebimentos        String   @default("[]") @db.NVarChar(Max) // [JSON] — recebimentos realizados (Receita/Ambos)
  aditivos            String   @default("[]") @db.NVarChar(Max) // [JSON] — termos aditivos (alteram término/valor/objeto/partes em vigor)
  documentos          String   @default("[]") @db.NVarChar(Max) // [JSON]
  renovacoes          String   @default("[]") @db.NVarChar(Max) // [JSON] renovações automáticas: [{ id, data, terminoAnterior, novoTermino, automatica }]
  reajustesRealizados String   @default("[]") @db.NVarChar(Max) // [JSON] reajustes efetivamente aplicados: [{ id, reajusteId, competencia, indiceSnapshot, percentual, valorAnterior, valorNovo, dataAplicacao, observacao, user, createdAt }]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  auditLogs     ContractAuditLog[]
  notifications Notification[]

  @@index([organizationId])
  @@map("contracts")
}

model ContractAuditLog {
  id         String   @id @default(cuid())
  contractId String
  user       String
  event      String   // CRIADO | ATUALIZADO | ATIVADO | EM_REVISAO | ENCERRADO | RESCINDIDO | ADITIVO | REAJUSTE | LANCAMENTO | DOCUMENTO
  motivo     String?
  changes    String   @default("[]") @db.NVarChar(Max) // [JSON] [{ field, label, before, after }]
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_audit_logs")
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  contractId     String
  tipo           String   // VIGENCIA | REAJUSTE | CONSUMO
  severidade     String   @default("INFO") // INFO | ALERTA | CRITICO
  titulo         String
  mensagem       String   @db.NVarChar(Max)
  dedupKey       String   // ex.: "vigencia:<contractId>:30" — único por org, evita duplicar
  createdAt      DateTime @default(now())

  contract Contract           @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reads    NotificationRead[]

  @@unique([organizationId, dedupKey])
  @@index([organizationId])
  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@map("notification_reads")
}

// ─── Documentos ──────────────────────────────────────────────────────────────

model Document {
  id             String   @id @default(cuid())
  moduleRecordId String
  name           String
  fileKey        String   // chave no Cloudflare R2
  fileSize       Int
  mimeType       String
  uploadedAt     DateTime @default(now())

  moduleRecord ModuleRecord @relation(fields: [moduleRecordId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("documents")
}

// ─── Configurações da aplicação (KV genérico) ────────────────────────────────
// Substitui o localStorage: tabelas auxiliares, definições de campos/seções,
// visões, ordem de coluna, rascunhos. userId="" = nível organização (compartilhado);
// quando houver login, configurações pessoais gravam com o id do usuário.

model AppSetting {
  id             String   @id @default(cuid())
  organizationId String
  userId         String   @default("")
  key            String
  value          String   @db.NVarChar(Max) // [JSON]
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, userId, key])
  @@index([organizationId, key])
  @@map("app_settings")
}

// ─── Estrutura organizacional ─────────────────────────────────────────────────
// Empresas do grupo + organograma (unidades organizacionais em árvore).
// Cada unidade tem uma "natureza": administrativa, centro de custo ou centro de lucro.

model GroupCompany {
  id             String   @id @default(cuid())
  organizationId String
  codigo         String?  // alfanumérico, até 15 posições, manual
  razaoSocial    String
  nomeFantasia   String?
  cnpj           String?
  ie             String?  // inscrição estadual
  im             String?  // inscrição municipal
  status         String   @default("ATIVA") // ATIVA | INATIVA
  // Campos PJ reaproveitados do cadastro de Parceiros (JSON serializado via middleware).
  contatos       String   @default("[]") @db.NVarChar(Max) // [JSON]
  enderecos      String   @default("[]") @db.NVarChar(Max) // [JSON]
  bancos         String   @default("[]") @db.NVarChar(Max) // [JSON]
  socios         String   @default("[]") @db.NVarChar(Max) // [JSON]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orgUnits OrgUnit[]

  @@index([organizationId])
  @@map("group_companies")
}

model OrgUnit {
  id             String   @id @default(cuid())
  organizationId String
  groupCompanyId String
  parentId       String?
  natureza       String   @default("ADMINISTRATIVA") // ADMINISTRATIVA | CENTRO_CUSTO | CENTRO_LUCRO
  codigo         String?
  nome           String
  responsavel    String?
  status         String   @default("ATIVA") // ATIVA | INATIVA
  usuarios       String   @default("[]") @db.NVarChar(Max) // [JSON] usuários envolvidos (lista livre)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  groupCompany GroupCompany @relation(fields: [groupCompanyId], references: [id], onDelete: Cascade)
  parent       OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     OrgUnit[]    @relation("OrgUnitTree")

  @@index([organizationId])
  @@index([groupCompanyId])
  @@map("org_units")
}
