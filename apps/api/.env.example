# SQL Server (banco oficial do produto). encrypt+trustServerCertificate cobrem dev local em Docker.
DATABASE_URL="sqlserver://localhost:1433;database=nxt;user=sa;password=SUA_SENHA;encrypt=true;trustServerCertificate=true"
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000

# Armazenamento de anexos. STORAGE_DRIVER: `local` (default, on-premise/dev) ou `r2`/`s3` (nuvem).
STORAGE_DRIVER=local
# Driver local: pasta relativa ao cwd da API (use um volume persistente em produção).
STORAGE_DIR=./uploads
# Driver r2/s3 (preencher ao subir na nuvem; ignorado quando STORAGE_DRIVER=local):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=          # opcional — para S3/MinIO genérico
# R2_REGION=auto        # opcional

# Autenticação própria — access token JWT (HS256) curto + refresh token opaco.
# AUTH_JWT_SECRET: em produção use uma string aleatória de 64+ caracteres
# (ex.: `openssl rand -base64 48`). A API se RECUSA a subir em produção se este
# valor parecer um placeholder de dev.
AUTH_JWT_SECRET=troque-por-uma-string-aleatoria-de-64-chars
AUTH_JWT_TTL=15m
AUTH_REFRESH_TTL_DAYS=7
# Anti-brute-force: bloqueio de conta após N falhas (por X min) e throttle por IP no login.
AUTH_MAX_FAILED=5
AUTH_LOCK_MINUTES=15
AUTH_IP_MAX=20

# Rate-limit GLOBAL (rede de segurança em toda a API, além do throttle de login).
# Generoso de propósito: parte do tráfego chega pelo BFF com um IP só. TTL em segundos.
THROTTLE_TTL=60
THROTTLE_LIMIT=300
# Claim que carrega o tenant no token (mantido por compatibilidade com os decorators).
OIDC_ORG_CLAIM=org_id
